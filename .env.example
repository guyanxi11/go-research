# ===== Server =====
SERVER_ADDR=:8080
LOG_LEVEL=info

# ===== LLM (OpenAI-compatible) =====
# 推荐 DeepSeek（便宜，国内可直连）：https://platform.deepseek.com/
#   BASE_URL=https://api.deepseek.com/v1
#   MODEL=deepseek-chat
# 也可换豆包/Kimi/OpenAI/OpenRouter，只要兼容 OpenAI Chat Completions 即可
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=deepseek-chat

# ===== Postgres (pgvector) =====
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=research
POSTGRES_PASSWORD=research
POSTGRES_DB=research

# ===== Redis =====
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== Tools (Phase 1 可不填) =====
TAVILY_API_KEY=
