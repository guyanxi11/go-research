# ===== Server =====
SERVER_ADDR=:8080
LOG_LEVEL=info

# ===== LLM (OpenAI-compatible) =====
# 推荐 DeepSeek（便宜，国内可直连）：https://platform.deepseek.com/
#   BASE_URL=https://api.deepseek.com/v1
#   MODEL=deepseek-chat
# 也可换豆包/Kimi/OpenAI/OpenRouter，只要兼容 OpenAI Chat Completions 即可
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=deepseek-chat

# ===== Postgres (Phase 3 必须；本机无需安装，用 docker compose 即可) =====
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=research
POSTGRES_PASSWORD=research
POSTGRES_DB=research

# ===== Redis =====
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== Tavily 联网搜索（Research 子任务用；不填则用 Mock 假数据）=====
# 注册：https://app.tavily.com/ → API Keys → 复制 tvly- 开头的 key
TAVILY_API_KEY=
# basic（省额度，默认）| advanced（质量更高，单次约 2 credits）
TAVILY_SEARCH_DEPTH=basic
