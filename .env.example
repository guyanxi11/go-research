# ===== Server =====
SERVER_ADDR=:8080
LOG_LEVEL=info
# 设置后所有 /api/* 请求必须带 X-API-Key: <值>；不设置保持公开（本地开发友好）
API_KEY=
# /api/research 总超时（秒）。0 关闭超时（仅本地调试使用，生产请保留）
RESEARCH_TIMEOUT_SECONDS=180

# ===== LLM (OpenAI-compatible) =====
# 推荐 DeepSeek（便宜，国内可直连）：https://platform.deepseek.com/
#   BASE_URL=https://api.deepseek.com/v1
#   MODEL=deepseek-chat
# 也可换豆包/Kimi/OpenAI/OpenRouter，只要兼容 OpenAI Chat Completions 即可
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=deepseek-chat

# ===== Postgres (Phase 3 必须；本机无需安装，用 docker compose 即可) =====
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=research
POSTGRES_PASSWORD=research
POSTGRES_DB=research

# ===== Redis =====
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== Tavily 联网搜索（Research 子任务用；不填则用 Mock 假数据）=====
# 注册：https://app.tavily.com/ → API Keys → 复制 tvly- 开头的 key
TAVILY_API_KEY=
# basic（省额度，默认）| advanced（质量更高，单次约 2 credits）
TAVILY_SEARCH_DEPTH=basic

# ===== Phase 4 Agent 调参 =====
# Researcher 每个子任务最多 ReAct 轮数（1 = 单轮，关闭多轮）
RESEARCH_MAX_SEARCH_ROUNDS=2
# 每轮最多追加的 follow-up query 条数
RESEARCH_MAX_FOLLOWUP_QUERIES=2
# Critic 开关：true 时对每个子任务的 findings 评分回退
CRITIC_ENABLED=true
# 通过分数阈值（1-10）；低于此分时 Researcher 会带反馈重做
CRITIC_MIN_SCORE=6
# 单个子任务最多被 Critic 打回重做的次数
CRITIC_MAX_RETRIES=1
